# Copy to .env and fill in after deploying the contract

# Soroban RPC endpoint (testnet)
REACT_APP_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Your deployed contract ID (get this after running stellar contract deploy)
REACT_APP_CONTRACT_ID=

# A funded Stellar testnet keypair secret (generate with: stellar keys generate --network testnet mykey)
REACT_APP_STELLAR_SECRET_KEY=
